# Uber MVP Backend - environment variables
# Copy to .env and fill in the values (never commit .env)
#
# All variables have documented safe defaults in src/uber/config.py.

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/uber

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Server bind address (default: 0.0.0.0)
HOST=0.0.0.0

# Server port inside the container (default: 8000)
PORT=8000

# Log level: debug, info, warning, error (default: info)
LOG_LEVEL=info
